# ─── 流量分析系统 环境配置 ───
# 复制为 .env 并按需修改

# API 认证（留空则不启用认证）
API_KEY=

# CORS 允许的来源（逗号分隔，空则允许全部）
ALLOWED_ORIGINS=

# Rust 日志级别 (debug / info / warn / error)
RUST_LOG=info

# ClickHouse 连接地址（Docker Compose 中为 clickhouse:8123）
CLICKHOUSE_HOST=localhost:8123

# 数据保留天数
CLICKHOUSE_TTL_DAYS=90

# 路由器 SSH 管理（留空则禁用 /api/agent/* 端点）
ROUTER_SSH_HOST=
ROUTER_SSH_PASSWORD=admin
ROUTER_SSH_PORT=22

# Agent 的 Ingest 连接地址（远程启动 agent 时使用）
INGEST_ADDR=192.168.66.186:9100
